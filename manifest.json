{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.28.5",
  "description": "__MSG_appDescription__",
  "default_locale": "en",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "sidePanel"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "shared/storage.js",
        "shared/icons.js",
        "shared/cache-server.js",
        "shared/cache-local.js",
        "shared/cache-manager.js",
        "content/domain-strategies.js",
        "content/translator.js",
        "content/translator-ui.js",
        "content/translator-cache.js",
        "content/translator-dom.js",
        "content/translator-export.js"
      ],
      "css": ["content/translator.css"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_appDefaultTitle__"
  },

  "side_panel": {
    "default_path": "pages/sidepanel.html"
  },

  "options_page": "pages/options.html",

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https: data:;"
  },

  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Translate selection"
    },
    "translate-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Translate page"
    },
    "toggle-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open side panel"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
